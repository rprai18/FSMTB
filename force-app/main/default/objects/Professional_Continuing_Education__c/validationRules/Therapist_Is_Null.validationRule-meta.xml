<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Therapist_Is_Null</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK( Contact__c )),
    NOT(ISPICKVAL(Upload_Status__c, &quot;Approved&quot;))
)</errorConditionFormula>
    <errorDisplayField>Upload_Status__c</errorDisplayField>
    <errorMessage>Therapist is requiered</errorMessage>
</ValidationRule>
