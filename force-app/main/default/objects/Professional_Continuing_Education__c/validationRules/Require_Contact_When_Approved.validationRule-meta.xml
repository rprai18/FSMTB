<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Contact_When_Approved</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Upload_Status__c, &quot;Approved&quot;),
    ISBLANK(Contact__c)
)</errorConditionFormula>
    <errorMessage>A Contact must be associated when Upload Status is Approved.</errorMessage>
</ValidationRule>
