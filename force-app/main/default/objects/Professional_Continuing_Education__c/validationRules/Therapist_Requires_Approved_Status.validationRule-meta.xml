<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Therapist_Requires_Approved_Status</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Contact__c)),
    NOT(ISPICKVAL(Upload_Status__c, &quot;Approved&quot;)),
    NOT(ISPICKVAL(Upload_Status__c, &quot;Canceled&quot;))
)</errorConditionFormula>
    <errorDisplayField>Upload_Status__c</errorDisplayField>
    <errorMessage>You must have an Upload Status of Approved if a Therapist is related to this record.</errorMessage>
</ValidationRule>
