<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Can_upload_Status_should_be_Canceled</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Upload_Status__c, &quot;Canceled&quot;),
    ISBLANK(Cancellation_Approver__c)
)</errorConditionFormula>
    <errorMessage>Upload Status should be Canceled</errorMessage>
</ValidationRule>
