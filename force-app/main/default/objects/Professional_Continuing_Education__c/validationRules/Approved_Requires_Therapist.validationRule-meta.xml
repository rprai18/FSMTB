<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Approved_Requires_Therapist</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Upload_Status__c, &quot;Approved&quot;),
    ISBLANK(Contact__c)
)</errorConditionFormula>
    <errorDisplayField>Contact__c</errorDisplayField>
    <errorMessage>You must update what Therapist this is related to if you are Approving the record.</errorMessage>
</ValidationRule>
