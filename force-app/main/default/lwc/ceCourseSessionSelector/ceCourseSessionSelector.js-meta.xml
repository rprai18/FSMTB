<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <isExposed>true</isExposed>

   
    

    <targets>
        <!-- For record pages (standard Lightning App Builder) -->
        <target>lightning__RecordPage</target>

        <!-- For Home pages (if you ever want it visible on Home) -->
        <target>lightning__HomePage</target>

        <!-- For App pages -->
        <target>lightning__AppPage</target>

        <!-- For Communities / Experience Cloud -->
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>

        <!-- For Flow screens -->
        <target>lightning__FlowScreen</target>
    </targets>

    <!-- For Flow inputs/outputs if you later add them 
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="recordId" type="String" label="Record Id" description="Record Id from Flow context" />
        </targetConfig>
    </targetConfigs>-->
</LightningComponentBundle>